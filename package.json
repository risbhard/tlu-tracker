{
  "name": "tlu-tracker",
  "version": "1.0.0",
  "author": {
  "name": "Rishi Bhardwaj",
  "email": "rbhardwaj@okanagan.bc.ca"
},
  "description": "Teaching Load Unit (TLU) Tracker",
  "main": "electron/main.js",
  "homepage": "./",
  "scripts": {
    "server": "node server/index.js",
    "client": "cd client && npm run dev",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "install-all": "npm install && cd client && npm install",
    "electron": "cd client && npm run build && cd .. && electron .",
    "electron-dev": "cd client && npm run build && cd .. && NODE_ENV=development electron .",
    "electron-build:win": "cd client && npm run build && cd .. && npx electron-builder --win portable --publish=never",
"electron-build:mac": "cd client && npm run build && cd .. && npx electron-builder --mac dmg --publish=never",
"electron-build": "cd client && npm run build && cd .. && npx electron-builder --publish=never"
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "pdfkit": "^0.18.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "electron": "^31.0.0",
    "electron-builder": "^25.1.1"
  },
  "build": {
    "appId": "com.tlutracker.app",
    "productName": "TLU Tracker",
    "files": [
      "!dist",
      "client/dist/**/*",
      "electron/**/*",
      "server/**/*",
      "assets/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*",
      "node_modules/bindings/**/*",
      "node_modules/file-uri-to-path/**/*",
      "**/*.node"
    ],
    "extraResources": [
      {
        "from": "client/public/Images",
        "to": "Images",
        "filter": ["tray-icon*.ico", "tray-icon*.png"]
      }
    ],
    "directories": {
      "buildResources": "assets"
    },
    "win": {
      "target": ["nsis", "portable"],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "mac": {
      "target": ["dmg", "zip"]
    },
    "linux": {
      "target": ["AppImage", "deb"]
    }
  }
}
